# Primary vision provider (solar panel defect detection)
GROQ_API_KEY='your_groq_api_key_here'

# Fallback vision provider if Groq fails
OPENROUTER_API_KEY='your_openrouter_api_key_here'

# Optional: NREL PVWatts (defaults to DEMO_KEY; get a free key at https://developer.nrel.gov)
NREL_API_KEY='your_nrel_api_key_here'

# Model overrides (long-lived free/low-cost defaults)
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
OPENROUTER_VISION_MODEL=google/gemma-3-27b-it:free

PORT=5000
